i, nrow(param_grid_nn), n_layers_i, units_i,
dropout_i, lr_i, best_val_auc, best_epoch))
tibble(
n_layers   = n_layers_i,
units      = units_i,
dropout    = dropout_i,
lr         = lr_i,
best_epoch = best_epoch,
val_AUC    = round(best_val_auc, 4)
)
})
